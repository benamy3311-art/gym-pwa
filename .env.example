# Firebase project config (Project Settings > General > Your apps > SDK setup and configuration)
# Copy this file to .env and fill in your own values. .env is gitignored.
VITE_FIREBASE_API_KEY=
# In production set this to the domain the app is served from (e.g. your-app.vercel.app),
# NOT <project>.firebaseapp.com. The app proxies /__/auth/* to Firebase (see vercel.json)
# so Google sign-in stays same-origin, which is required for Safari/iOS installed PWAs.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
